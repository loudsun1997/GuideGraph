{
  "compilerOptions": {
    "allowSyntheticDefaultImports": true,
    "baseUrl": ".",
    "declaration": true,
    "declarationMap": true,
    "exactOptionalPropertyTypes": true,
    "lib": [
      "ES2023",
      "DOM"
    ],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "newLine": "lf",
    "noEmitOnError": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitOverride": true,
    "noImplicitReturns": true,
    "noUncheckedIndexedAccess": true,
    "paths": {
      "@guidegraph/core": [
        "packages/core/src/index.ts"
      ],
      "@guidegraph/builder": [
        "packages/builder/src/index.ts"
      ],
      "@guidegraph/devtools": [
        "packages/devtools/src/index.ts"
      ],
      "@guidegraph/graph": [
        "packages/graph/src/index.ts"
      ],
      "@guidegraph/http": [
        "packages/http/src/index.ts"
      ],
      "@guidegraph/mcp": [
        "packages/mcp/src/index.ts"
      ],
      "@guidegraph/react": [
        "packages/react/src/index.tsx"
      ],
      "@guidegraph/react-builder": [
        "packages/react-builder/src/index.tsx"
      ],
      "@guidegraph/react-graph": [
        "packages/react-graph/src/index.tsx"
      ],
      "@guidegraph/server": [
        "packages/server/src/index.ts"
      ],
      "@guidegraph/storage-memory": [
        "packages/storage-memory/src/index.ts"
      ],
      "@guidegraph/storage-postgres": [
        "packages/storage-postgres/src/index.ts"
      ]
    },
    "skipLibCheck": true,
    "strict": true,
    "target": "ES2023",
    "verbatimModuleSyntax": true
  }
}
