{
  "name": "@guidegraph/mcp",
  "version": "0.1.0-alpha.0",
  "description": "MCP server tools for validating, building, and simulating GuideGraph workflows.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "guidegraph-mcp": "./dist/stdio.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./stdio": {
      "types": "./dist/stdio.d.ts",
      "default": "./dist/stdio.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -b",
    "test": "vitest run tests",
    "typecheck": "tsc -b --pretty false",
    "clean": "tsc -b --clean"
  },
  "dependencies": {
    "@guidegraph/builder": "workspace:*",
    "@guidegraph/core": "workspace:*"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/loudsun1997/GuideGraph.git",
    "directory": "packages/mcp"
  },
  "bugs": {
    "url": "https://github.com/loudsun1997/GuideGraph/issues"
  },
  "homepage": "https://github.com/loudsun1997/GuideGraph/tree/main/packages/mcp#readme",
  "keywords": [
    "guidegraph",
    "workflow",
    "workflow-engine",
    "typescript",
    "mcp",
    "model-context-protocol",
    "ai"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20"
  }
}
