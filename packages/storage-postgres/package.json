{
  "name": "@guidegraph/storage-postgres",
  "version": "0.1.0-alpha.0",
  "description": "Postgres workflow storage for GuideGraph.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "schema.sql",
    "migrations"
  ],
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc -b --pretty false",
    "test": "vitest run tests",
    "clean": "tsc -b --clean"
  },
  "dependencies": {
    "@guidegraph/core": "workspace:*",
    "@guidegraph/server": "workspace:*"
  },
  "peerDependencies": {
    "pg": ">=8"
  },
  "peerDependenciesMeta": {
    "pg": {
      "optional": true
    }
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/loudsun1997/GuideGraph.git",
    "directory": "packages/storage-postgres"
  },
  "bugs": {
    "url": "https://github.com/loudsun1997/GuideGraph/issues"
  },
  "homepage": "https://github.com/loudsun1997/GuideGraph/tree/main/packages/storage-postgres#readme",
  "keywords": [
    "guidegraph",
    "workflow",
    "workflow-engine",
    "typescript",
    "postgres",
    "persistence"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20"
  },
  "sideEffects": false
}
