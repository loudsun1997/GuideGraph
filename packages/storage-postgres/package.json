{
  "name": "@flowforge/storage-postgres",
  "version": "0.1.0",
  "description": "Postgres workflow storage for FlowForge.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "schema.sql"
  ],
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc -b --pretty false",
    "test": "vitest run tests",
    "clean": "tsc -b --clean"
  },
  "dependencies": {
    "@flowforge/core": "workspace:*",
    "@flowforge/server": "workspace:*"
  },
  "peerDependencies": {
    "pg": ">=8"
  },
  "peerDependenciesMeta": {
    "pg": {
      "optional": true
    }
  }
}
