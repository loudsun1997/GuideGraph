{
  "name": "@guidegraph/react-graph",
  "version": "0.1.0-alpha.0",
  "description": "Optional React Flow graph renderer for GuideGraph.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -b",
    "test": "vitest run tests",
    "typecheck": "tsc -b --pretty false",
    "clean": "tsc -b --clean"
  },
  "dependencies": {
    "@guidegraph/graph": "workspace:*",
    "@guidegraph/react": "workspace:*",
    "@xyflow/react": "^12.10.2",
    "elkjs": "^0.11.1"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/loudsun1997/GuideGraph.git",
    "directory": "packages/react-graph"
  },
  "bugs": {
    "url": "https://github.com/loudsun1997/GuideGraph/issues"
  },
  "homepage": "https://github.com/loudsun1997/GuideGraph/tree/main/packages/react-graph#readme",
  "keywords": [
    "guidegraph",
    "workflow",
    "workflow-engine",
    "typescript",
    "react-flow",
    "graph",
    "visualization"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20"
  },
  "sideEffects": false
}
