{
  "name": "@flowforge/http",
  "version": "0.1.0",
  "description": "HTTP transport for FlowForge clients and servers.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -b",
    "test": "vitest run tests",
    "typecheck": "tsc -b --pretty false",
    "clean": "tsc -b --clean"
  },
  "dependencies": {
    "@flowforge/core": "workspace:*",
    "@flowforge/server": "workspace:*"
  }
}
