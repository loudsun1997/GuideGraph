{
  "name": "flowforge",
  "version": "0.1.0",
  "description": "Developer toolkit for building workflows.",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -b",
    "build:examples": "pnpm --filter @flowforge/permit-app build",
    "dev:permit": "pnpm --filter @flowforge/permit-app dev",
    "typecheck": "tsc -b --pretty false",
    "test": "vitest run",
    "test:core": "vitest run packages/core/tests",
    "test:server": "vitest run packages/server/tests",
    "test:postgres": "vitest run packages/storage-postgres/tests",
    "clean": "tsc -b --clean"
  },
  "devDependencies": {
    "@types/node": "^22.13.1",
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.2.3",
    "pg-mem": "^3.0.14",
    "typescript": "^5.7.3",
    "vite": "^8.0.11",
    "vitest": "^4.1.5"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.23.0",
  "dependencies": {
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  }
}
